# Database Configuration
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=iam_db
DB_SSLMODE=disable

# Server Configuration
PORT=8080
GIN_MODE=release

# Monitoring
PROMETHEUS_ENABLED=true
PROMETHEUS_PORT=2112

# Logging
LOG_LEVEL=info

# S2S Authentication
# ------------------------------------------------------------------------------
# Cada servicio consumidor tiene su propia API key. Los valores reales viven en
# GitHub Actions Secrets (CI) o sealed-secrets (k3s). NUNCA se commitean.
#
# Para dev local, generá keys distintas por servicio con:
#   openssl rand -hex 32
# y pegalas acá en tu .env (no en .env.example).
#
# Política de scopes (no secreta, vive en src/auth/infrastructure/s2s/registry.go):
#   - whatsapp-agent  → tenant:provision  (solo crea tenants + owner)
#   - onboarding      → system:admin      (legacy, igual al god-key anterior)
#   - sales           → system:admin      (legacy)
#   - pim             → system:admin      (legacy)
S2S_KEY_WHATSAPP_AGENT=
S2S_KEY_ONBOARDING=
S2S_KEY_SALES=
S2S_KEY_PIM=
